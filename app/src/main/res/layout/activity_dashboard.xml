<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A237E"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏪 BazaarIQ"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTodaySales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today Sales: ₹0.0"
            android:textColor="#90CAF9"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvTodayPayment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today Received: ₹0.0"
            android:textColor="#A5D6A7"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnAddUdari"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:text="💰 Add\nUdari"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#D32F2F"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnAddPayment"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:text="✅ Add\nPayment"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnCustomers"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="👥 View Customers"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#1565C0"
        android:layout_marginHorizontal="16dp"/>

</LinearLayout>